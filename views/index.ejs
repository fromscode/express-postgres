<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>
</head>
<body>
    <h1>Usernames: </h1>
    <ol>
        <% usernames.forEach(username => { %>
            <li><%= username.username %></li>
        <% }) %>
    </ol>
    <div>
        <a href="/new">Add a user</a>
    </div>
</body>
</html>