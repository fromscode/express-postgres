<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>
</head>
<body>
    <form action="/search" method="get">
        <input type="text" placeholder="Enter name to search" name="param">
        <button type="submit">Search</button>
    </form>
    <%- include('validationErrors') %>
    <h1>Usernames: </h1>
    <ol>
        <% usernames.forEach(username => { %>
            <li><%= username.username %></li>
        <% }) %>
    </ol>
    <div>
        <a href="/new">Add a user</a>
    </div>
    <form action="/delete" method="post">
        <button type="submit" onclick="return confirm('Are you sure you want to delete this user?');">Delete All Users</button>
      </form>
</body>
</html>